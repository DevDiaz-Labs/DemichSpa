---
// Services.astro
const services = [
  {
    id: 1,
    title: 'Masajes Relajantes',
    description: 'Libera la tensión de tu cuerpo y mente. Terapias diseñadas para brindarte beneficios inmensos y paz profunda.',
    image: 'https://images.unsplash.com/photo-1519823551278-64ac92734fb1?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80',
    link: '#contact'
  },
  {
    id: 2,
    title: 'Masajes Linfáticos Post Operatorios',
    description: 'Tratamientos especializados para reducir la inflamación, mejorar la circulación y acelerar tu recuperación tras una cirugía.',
    image: 'https://images.unsplash.com/photo-1600334129128-685c5582fd35?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80',
    link: '#contact'
  },
  {
    id: 3,
    title: 'Reductivos',
    description: 'Técnicas avanzadas para moldear tu figura, reducir medidas y tonificar tu cuerpo de manera efectiva y segura.',
    image: 'https://images.unsplash.com/photo-1544161515-4ab6ce6db874?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80',
    link: '#contact'
  },
  {
    id: 4,
    title: 'Faciales',
    description: 'Rejuvenece tu piel con un facial personalizado a tus necesidades específicas. Luce y siéntete radiante.',
    image: 'https://images.unsplash.com/photo-1515377905703-c4788e51af15?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80',
    link: '#contact'
  }
];
---

<section id="services" class="section services">
  <div class="container">
    <div class="section-header">
      <h2>Nuestros Servicios</h2>
      <div class="gold-separator mx-auto"></div>
      <p class="subtitle">En Spa Demich, te aseguramos cubrir todas tus necesidades de belleza y bienestar con los mejores productos y terapeutas especialistas.</p>
    </div>

    <div class="carousel-wrapper" id="services-carousel">
      <button class="carousel-btn prev-btn" aria-label="Anterior">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      
      <div class="services-grid track">
        {services.map(service => (
          <div class="service-card item">
            <div class="card-image-wrapper">
              <img src={service.image} alt={service.title} class="card-image" />
            </div>
            <div class="card-content">
              <h3>{service.title}</h3>
              <p>{service.description}</p>
              <a href={service.link} class="card-link">Reservar &rarr;</a>
            </div>
          </div>
        ))}
      </div>

      <button class="carousel-btn next-btn" aria-label="Siguiente">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>

    <div class="actions">
      <a href="/servicios" class="btn btn-outline">Ver Todos los Servicios</a>
    </div>
  </div>
</section>

<style>
  .services {
    /* Uses global pure background */
    background-color: transparent; 
  }

  .section-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 3rem auto;
  }

  .gold-separator {
    height: 2px;
    width: 60px;
    background-color: var(--c-primary);
    margin: 1rem auto 1.5rem auto;
  }

  .subtitle {
    font-size: 1.125rem;
    color: var(--c-text-light);
  }

  .carousel-wrapper {
    position: relative;
    margin-bottom: 4rem;
    min-width: 0; /* Fix flex/grid blowout */
    width: 100%;
  }

  .carousel-btn {
    display: none; /* Hidden on desktop by default as grid is used */
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
  }

  .service-card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 10px 30px rgba(0,0,0,0.06);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    background-color: #ffffff;
    border: 1px solid rgba(0,0,0,0.03);
  }

  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 40px rgba(212, 175, 55, 0.15); /* Toque elegante con luz dorada en sombra */
  }

  .card-image-wrapper {
    width: 100%;
    height: 260px;
    overflow: hidden;
    position: relative;
  }

  .card-image-wrapper::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 40%;
    background: linear-gradient(to top, rgba(0,0,0,0.15) 0%, transparent 100%);
    pointer-events: none;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.7s ease;
  }

  .service-card:hover .card-image {
    transform: scale(1.08);
  }

  .card-content {
    background-color: var(--c-bg-soft, #ffffff);
    padding: 2rem 1.5rem;
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex-grow: 1;
  }

  .card-content h3 {
    font-size: 1.35rem;
    margin-bottom: 0.85rem;
    font-family: var(--font-heading);
    color: var(--c-text-main);
  }

  .card-content p {
    font-size: 0.95rem;
    margin-bottom: 1.8rem;
    flex-grow: 1;
    color: var(--c-text-light);
    line-height: 1.6;
  }

  .card-link {
    font-weight: 600;
    color: var(--c-primary);
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 1px;
    display: inline-block;
    padding: 0.6rem 1.8rem;
    border: 1px solid var(--c-primary);
    border-radius: 30px;
    transition: all 0.3s ease;
  }

  .card-link:hover {
    background-color: var(--c-primary);
    color: #fff;
    text-decoration: none;
  }

  .actions {
    text-align: center;
    margin-top: 2rem;
  }

  .btn-outline {
    background-color: transparent;
    color: var(--c-primary);
    border: 2px solid var(--c-primary);
  }

  .btn-outline:hover {
    background-color: var(--c-primary);
    color: white;
  }

  @media (max-width: 1200px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .carousel-wrapper {
      position: relative;
      margin-bottom: 2rem;
    }
    
    .services-grid {
      display: flex;
      flex-wrap: nowrap;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      gap: 1rem;
      padding-bottom: 2rem; /* space for scrollbar/shadows */
      -webkit-overflow-scrolling: touch;
      /* Hide scrollbar logically but allow scrolling */
      scrollbar-width: none; 
    }
    
    .services-grid::-webkit-scrollbar {
      display: none;
    }

    .service-card {
      flex: 0 0 85%;
      scroll-snap-align: center;
    }

    .card-content {
      margin: -2rem 1rem 0 1rem;
    }

    .carousel-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      position: absolute;
      top: 40%;
      transform: translateY(-50%);
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.95);
      color: var(--c-text-main, #333);
      border: none;
      z-index: 10;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
      cursor: pointer;
      backdrop-filter: blur(4px);
      transition: all 0.3s ease;
    }
    .carousel-btn:hover { 
      background: var(--c-primary, #d4af37); 
      color: #fff;
      box-shadow: 0 8px 25px rgba(212, 175, 55, 0.3);
      transform: translateY(-50%) scale(1.05);
    }
    .prev-btn { left: 5px; }
    .next-btn { right: 5px; }
  }
</style>

<script>
  // Simple infinite carousel script for Services
  const container = document.getElementById('services-carousel');
  if (container) {
    const track = container.querySelector('.track');
    const prevBtn = container.querySelector('.prev-btn');
    const nextBtn = container.querySelector('.next-btn');

    if (track && prevBtn && nextBtn) {
      prevBtn.addEventListener('click', () => {
        const item = track.querySelector('.item');
        if (item) {
          const gap = 16;
          if (track.scrollLeft <= 10) {
            track.scrollTo({ left: track.scrollWidth, behavior: 'smooth' });
          } else {
            track.scrollBy({ left: -(item.clientWidth + gap), behavior: 'smooth' });
          }
        }
      });
      nextBtn.addEventListener('click', () => {
        const item = track.querySelector('.item');
        if (item) {
          const gap = 16;
          if (track.scrollLeft + track.clientWidth >= track.scrollWidth - 10) {
            track.scrollTo({ left: 0, behavior: 'smooth' });
          } else {
            track.scrollBy({ left: (item.clientWidth + gap), behavior: 'smooth' });
          }
        }
      });
    }
  }
</script>
