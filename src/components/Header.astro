---
// Header.astro
---
<header class="header">
  <div class="container header-content">
    <div class="logo">
      <a href="/">
        <img src="/images/logo2.png" alt="Spa Demich Logo" class="logo-img" />
      </a>
    </div>

    <!-- Desktop Menu -->
    <nav class="nav-desktop">
      <ul>
        <li><a href="/">Inicio</a></li>
        <li><a href="#services">Servicios</a></li>
        <li><a href="#contact">Citas</a></li>
        <li><a href="#contact">Ubicación</a></li>
      </ul>
    </nav>

    <div class="cta">
      <a href="#contact" class="btn btn-sm">Reservar Ahora</a>
    </div>

    <!-- Mobile Menu Button -->
    <button class="mobile-menu-btn" aria-label="Open menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>
</header>

<style>
  .header {
    position: relative; /* relative para no solapar a los servicios que ahora van primero */
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background-color: #ffffff;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.03);
  }

  .header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 75px; /* Más finito */
  }

  .logo {
    display: flex;
    align-items: center;
  }

  .logo-img {
    height: 55px; /* Proporcional a la nueva altura pura */
    width: auto;
    object-fit: contain;
    display: block;
    mix-blend-mode: multiply;
    transition: transform 0.3s ease;
  }

  .logo-img:hover {
    transform: scale(1.02);
  }

  .nav-desktop {
    flex-grow: 1;
    display: flex;
    justify-content: center;
  }

  .nav-desktop ul {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 2.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-desktop a {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--c-text-main, #333);
    text-transform: uppercase;
    letter-spacing: 1px;
    position: relative;
    padding-bottom: 5px;
    transition: color 0.3s ease;
  }

  .nav-desktop a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0%;
    height: 2px;
    background-color: var(--c-primary);
    transition: width 0.3s ease;
  }

  .nav-desktop a:hover {
    color: var(--c-primary);
    text-decoration: none;
  }

  .nav-desktop a:hover::after {
    width: 100%;
  }

  .cta {
    display: flex;
    align-items: center;
  }

  .btn-sm {
    padding: 0.6rem 1.8rem;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
    border-radius: 30px;
    background-color: var(--c-primary);
    color: #fff;
    border: 2px solid var(--c-primary);
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .btn-sm:hover {
    background-color: transparent;
    color: var(--c-primary);
  }

  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    color: var(--c-text-main);
    cursor: pointer;
    padding: 0.5rem;
  }

  @media (max-width: 992px) {
    .nav-desktop { display: none; }
    .mobile-menu-btn { display: none; } /* Ocultar hamburguesa a petición */
    .header-content { height: 70px; }
    .logo-img { height: 45px; }
  }
  
  @media (max-width: 576px) {
    /* Mostrar el botón CTA en lugar de la hamburguesa */
    .cta { display: flex; } 
    .btn-sm {
      padding: 0.5rem 1.2rem;
      font-size: 0.75rem;
    }
  }
</style>
