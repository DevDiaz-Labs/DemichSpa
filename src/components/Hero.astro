---
// Hero.astro
---

<section class="hero">
  <div class="hero-bg">
    <img src="/images/HERO.avif" alt="Spa Demich - Experiencia Relajante" class="hero-image" />
    <div class="hero-overlay"></div>
  </div>

  <div class="hero-content">
    <div class="hero-logo">
      <img src="/images/logo.png" alt="Demich Spa" />
    </div>

    <h1 class="hero-title">
      <span class="title-line">Bienvenido a</span>
      <span class="title-main">Demich Spa</span>
    </h1>
    
    <div class="gold-accent"></div>

    <p class="hero-description">
      Tu refugio de bienestar y belleza. Combinamos técnicas únicas y productos 
      de alta calidad para brindarte una experiencia inolvidable.
    </p>

    <div class="hero-actions">
      <a href="#contact" class="btn-primary">Agendar Cita</a>
      <a href="#services" class="btn-outline">Ver Servicios</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    /* Compensar la altura del header para que encaje EXACTO en la pantalla */
    min-height: calc(100vh - 100px);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding-bottom: 4rem; /* Dar espacio para el indicador de scroll */
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  
  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    animation: slowZoom 20s ease-out infinite alternate;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.45) 0%,
      rgba(0, 0, 0, 0.25) 50%,
      rgba(0, 0, 0, 0.45) 100%
    );
  }

  .hero-content {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 900px;
    padding: 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Contenedor elegante y cuadrado para el logo */
  .hero-logo {
    background: #ffffff;
    padding: 1rem; /* Padding más compacto */
    border-radius: 8px; 
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.25);
    margin-bottom: 1.5rem; /* Margen inferior reducido */
    animation: fadeUp 1s cubic-bezier(0.22,0.85,0.32,1) forwards;
  }

  .hero-logo img {
    max-width: 160px; /* Tamaño del logo super reducido para encajar perfecto */
    height: auto;
    display: block;
  }

  .hero-title {
    font-family: var(--font-heading, serif);
    font-size: clamp(3rem, 6.5vw, 4.2rem); /* Letras más grandes para destacar en PC */
    font-weight: 500;
    color: #fff;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    text-shadow: 0 4px 30px rgba(0, 0, 0, 0.4);
    animation: fadeUp 1s cubic-bezier(0.22,0.85,0.32,1) 0.2s forwards;
    opacity: 0;
  }

  .title-line {
    display: block;
    font-size: 1.25rem;
    font-weight: 400;
    font-style: italic;
    letter-spacing: 3px;
    margin-bottom: 0.5rem;
    color: rgba(255, 255, 255, 0.9);
  }

  .title-main {
    display: block;
    text-transform: uppercase;
    letter-spacing: 4px;
  }

  .gold-accent {
    width: 80px;
    height: 2px;
    background: var(--c-primary, #d4af37);
    margin-bottom: 1.5rem;
    animation: fadeUp 1s cubic-bezier(0.22,0.85,0.32,1) 0.4s forwards;
    opacity: 0;
  }

  .hero-description {
    font-family: var(--font-body, sans-serif);
    font-size: 1.25rem; /* Texto descriptivo más grande en computadora */
    color: rgba(255, 255, 255, 0.9);
    line-height: 1.6;
    max-width: 650px;
    margin: 0 auto 2rem auto;
    font-weight: 400;
    animation: fadeUp 1s cubic-bezier(0.22,0.85,0.32,1) 0.5s forwards;
    opacity: 0;
  }

  .hero-actions {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
    animation: fadeUp 1s cubic-bezier(0.22,0.85,0.32,1) 0.6s forwards;
    opacity: 0;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 3rem; 
    background-color: var(--c-primary, #d4af37);
    color: #ffffff;
    font-size: 0.95rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    border-radius: 50px;
    text-decoration: none;
    transition: all 0.3s ease;
    border: 2px solid var(--c-primary, #d4af37);
    box-shadow: 0 10px 30px rgba(212, 175, 55, 0.35);
  }

  .btn-primary:hover {
    background-color: transparent;
    color: #fff;
    border-color: #fff;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
    transform: translateY(-3px);
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 3rem;
    background-color: transparent;
    color: #fff;
    font-size: 0.95rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    border-radius: 50px;
    text-decoration: none;
    transition: all 0.3s ease;
    border: 2px solid #fff;
  }

  .btn-outline:hover {
    background-color: #fff;
    color: var(--c-secondary, #1a1a1a);
    transform: translateY(-3px);
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes slowZoom {
    0%   { transform: scale(1); }
    100% { transform: scale(1.08); }
  }

  @media (max-width: 768px) {
    .hero-logo {
      padding: 0.8rem;
      margin-bottom: 1rem;
    }
    .hero-logo img {
      max-width: 120px; /* Súper pequeño en celular para dejar espacio */
    }
    
    .hero-description {
      font-size: 0.95rem;
      margin-bottom: 1.5rem;
    }

    .hero-actions {
      flex-direction: column;
      gap: 0.8rem;
      width: 100%;
      padding: 0 1.5rem;
    }
    
    .btn-primary, .btn-outline {
      width: 100%;
      padding: 0.8rem;
    }
  }
</style>
