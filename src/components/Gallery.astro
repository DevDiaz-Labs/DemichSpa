---
// Gallery.astro
const images = [
  "https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
  "https://images.unsplash.com/photo-1512290923902-8a9f81dc236c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
  "https://images.unsplash.com/photo-1616394584738-fc6e612e71b9?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
  "https://images.unsplash.com/photo-1620216743956-6518172c9181?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
  "https://images.unsplash.com/photo-1544161513-0182559fd9ef?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
];
---
<section class="section gallery">
  <div class="container text-center">
    <h2>Galería</h2>
    <div class="gold-separator"></div>
    
    <div class="gallery-grid">
      <div class="item main-item">
        <img src={images[0]} alt="Spa treatment" />
      </div>
      <div class="item sub-item-1">
        <img src={images[1]} alt="Spa treatment" />
      </div>
      <div class="item sub-item-2">
        <img src={images[2]} alt="Spa treatment" />
      </div>
      <div class="item sub-item-3">
        <img src={images[3]} alt="Spa treatment" />
      </div>
      <div class="item sub-item-4">
        <img src={images[4]} alt="Spa treatment" />
      </div>
    </div>
  </div>
</section>

<style>
  .gallery {
    background-color: transparent;
  }

  .text-center {
    text-align: center;
  }

  h2 {
    margin-bottom: 0.5rem;
  }

  .gold-separator {
    height: 2px;
    width: 60px;
    background-color: var(--c-primary);
    margin: 1rem auto 3rem auto;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-template-rows: repeat(2, 250px);
    gap: 1rem;
  }

  .item {
    overflow: hidden;
    position: relative;
  }

  .item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition);
  }

  .item:hover img {
    transform: scale(1.05);
  }

  /* 
   * Mimicking the layout from the image: 
   * Left side: One large vertical image
   * Middle: 2 stacked horizontal images
   * Right side: 2 stacked horizontal images
   */
  .main-item {
    grid-column: 1 / 3;
    grid-row: 1 / 3;
  }

  .sub-item-1 { grid-column: 3 / 4; grid-row: 1 / 2; }
  .sub-item-2 { grid-column: 4 / 5; grid-row: 1 / 2; }
  .sub-item-3 { grid-column: 3 / 4; grid-row: 2 / 3; }
  .sub-item-4 { grid-column: 4 / 5; grid-row: 2 / 3; }

  @media (max-width: 992px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: auto;
    }
    .main-item { grid-column: 1 / 3; grid-row: 1; height: 400px; }
    .sub-item-1 { grid-column: 1; grid-row: 2; height: 250px; }
    .sub-item-2 { grid-column: 2; grid-row: 2; height: 250px; }
    .sub-item-3 { grid-column: 1; grid-row: 3; height: 250px; }
    .sub-item-4 { grid-column: 2; grid-row: 3; height: 250px; }
  }
  
  @media (max-width: 576px) {
    .gallery-grid { grid-template-columns: 1fr; }
    .item, .main-item, .sub-item-1, .sub-item-2, .sub-item-3, .sub-item-4 {
      grid-column: 1;
      grid-row: auto;
      height: 300px;
    }
  }
</style>
